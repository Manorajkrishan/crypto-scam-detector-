# Etherscan API (required for live blockchain data)
# Get free key: https://etherscan.io/myapikey
ETHERSCAN_API_KEY=YourApiKeyToken

# Chainabuse API (optional — enables live scam report lookup)
# Get key: https://www.chainabuse.com → Profile → Settings → API key
CHAINABUSE_API_KEY=

# PostgreSQL (optional — stores scan history)
# DATABASE_URL=postgresql://user:password@localhost:5432/crypto_risk
# PGSSL=false

# Server
PORT=3001
FRONTEND_URL=http://localhost:5173

# Python path for ML predictions
PYTHON_PATH=python
